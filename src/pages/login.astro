---
import Layout from '../layouts/Layout.astro';

if (Astro.locals.user) {
  return Astro.redirect('/');
}
---

<Layout title="Iniciar Sesión">
  <div class="min-h-[70vh] sm:min-h-[80vh] flex items-center justify-center px-2">
    <div class="aoe-panel w-full max-w-md">
      <div class="text-center mb-6 sm:mb-8">
        <span class="text-4xl sm:text-5xl mb-3 sm:mb-4 block">⚔️</span>
        <h1 class="aoe-title text-2xl sm:text-3xl mb-2">AoE3 Tracker</h1>
        <p class="text-aoe-cream-dark text-sm sm:text-base">Inicia sesión para continuar</p>
      </div>

      <form id="loginForm" class="space-y-6">
        <div>
          <label for="email" class="block text-sm font-semibold text-aoe-cream mb-2">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="aoe-input"
            placeholder="tu@email.com"
          />
        </div>

        <div>
          <label for="password" class="block text-sm font-semibold text-aoe-cream mb-2">
            Contraseña
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            class="aoe-input"
            placeholder="••••••••"
          />
        </div>

        <div id="error" class="hidden text-red-400 text-sm text-center p-2 bg-red-900/20 rounded"></div>

        <button type="submit" class="aoe-btn-primary w-full">
          Entrar al Campo de Batalla
        </button>
      </form>

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-aoe-gold/30"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-aoe-brown text-aoe-cream-dark">o</span>
        </div>
      </div>

      <button id="googleBtn" class="w-full flex items-center justify-center gap-3 px-4 py-3 border border-aoe-gold/30 rounded-lg bg-aoe-brown-light/30 hover:bg-aoe-gold/10 transition-colors text-aoe-cream">
        <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Continuar con Google
      </button>

      <div class="flex items-center justify-between mt-6">
        <a href="/register" class="text-aoe-gold hover:text-aoe-gold-light transition-colors text-sm">
          Crear cuenta
        </a>
        <button id="forgotBtn" class="text-aoe-cream-dark hover:text-aoe-cream transition-colors text-sm">
          Olvidé mi contraseña
        </button>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { getFirebaseAuth, googleProvider } from '../lib/firebase/client';
  import { signInWithEmailAndPassword, signInWithPopup, sendPasswordResetEmail } from 'firebase/auth';

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const errorDiv = document.getElementById('error') as HTMLDivElement;
  const googleBtn = document.getElementById('googleBtn') as HTMLButtonElement;
  const forgotBtn = document.getElementById('forgotBtn') as HTMLButtonElement;

  function showError(msg: string) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
  }

  async function sendTokenToServer(idToken: string, endpoint = '/api/auth/session') {
    const res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idToken }),
    });
    return res.json();
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const email = (form.querySelector('#email') as HTMLInputElement).value;
    const password = (form.querySelector('#password') as HTMLInputElement).value;

    try {
      const auth = getFirebaseAuth();
      const cred = await signInWithEmailAndPassword(auth, email, password);
      const idToken = await cred.user.getIdToken();
      const result = await sendTokenToServer(idToken);

      if (result.success) {
        window.location.href = '/';
      } else {
        showError(result.error || 'Error al iniciar sesión');
      }
    } catch (err: any) {
      if (err.code === 'auth/invalid-credential' || err.code === 'auth/wrong-password' || err.code === 'auth/user-not-found') {
        showError('Email o contraseña incorrectos');
      } else {
        showError('Error de conexión');
      }
    }
  });

  googleBtn.addEventListener('click', async () => {
    errorDiv.classList.add('hidden');
    try {
      const auth = getFirebaseAuth();
      const cred = await signInWithPopup(auth, googleProvider);
      const idToken = await cred.user.getIdToken();
      const result = await sendTokenToServer(idToken);

      if (result.success) {
        window.location.href = result.isNewUser ? '/profile' : '/';
      } else {
        showError(result.error || 'Error con Google');
      }
    } catch (err: any) {
      if (err.code !== 'auth/popup-closed-by-user') {
        showError('Error al iniciar con Google');
      }
    }
  });

  forgotBtn.addEventListener('click', async () => {
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const email = emailInput.value;
    if (!email) {
      showError('Ingresá tu email primero');
      return;
    }
    try {
      const auth = getFirebaseAuth();
      await sendPasswordResetEmail(auth, email);
      errorDiv.textContent = 'Email de recuperación enviado. Revisá tu bandeja.';
      errorDiv.classList.remove('hidden');
      errorDiv.classList.remove('text-red-400', 'bg-red-900/20');
      errorDiv.classList.add('text-green-400', 'bg-green-900/20');
    } catch {
      showError('No se pudo enviar el email. Verificá la dirección.');
    }
  });
</script>
